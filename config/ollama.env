# /etc/nanobot/ollama.env
# Sourced by the ollama systemd service.
# This file is a TEMPLATE — install.sh will overwrite it on the target VM with
# values from the .env file in the repo root (or its built-in defaults).
#
# Common knobs:
#   OLLAMA_HOST               bind address (default 127.0.0.1:11434)
#   OLLAMA_MODELS             where downloaded model blobs live
#   OLLAMA_NUM_PARALLEL       concurrent request slots (raise for multi-user)
#   OLLAMA_MAX_LOADED_MODELS  simultaneous loaded models in VRAM
#   OLLAMA_KEEP_ALIVE         idle time before a model is unloaded (e.g. 5m, 1h)
#   OLLAMA_FLASH_ATTENTION    1 to enable flash attention (recommended on GPU)
#   OLLAMA_SCHED_SPREAD       1 to spread models evenly across multiple GPUs
#
# Context length is set per-model via a Modelfile alias in install.sh, not here.
# Override at runtime by setting OLLAMA_CONTEXT_LENGTH_DEFAULT below — it is
# read by scripts/update-model.sh when (re)creating model aliases.

OLLAMA_HOST=127.0.0.1:11434
OLLAMA_MODELS=/var/lib/ollama/models
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=10m
OLLAMA_FLASH_ATTENTION=1
OLLAMA_CONTEXT_LENGTH_DEFAULT=8192
